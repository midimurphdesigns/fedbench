# Copy to .env and fill in your keys. Never commit .env.
# Bun loads .env automatically — no dotenv import needed.

# Required: primary LLM provider for the agent and smoke test
ANTHROPIC_API_KEY=sk-ant-...

# Optional: secondary provider for cross-provider evaluation
OPENAI_API_KEY=sk-...

# Optional: open-weights provider used as the lowest rung of the fallback ladder
OPENROUTER_API_KEY=sk-or-...
