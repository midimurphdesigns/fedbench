# Dependencies
node_modules/
bun.lockb

# Build / runtime artifacts
dist/
out/
build/
*.tsbuildinfo
*.tgz

# Environment / secrets — keep .env.example only
.env
.env.local
.env.*.local
!.env.example

# Caches / coverage / logs
.cache/
.eslintcache
.turbo/
coverage/
*.lcov
logs/
*.log

# Eval / observability outputs (large, local-only)
.promptfoo/
phoenix.db
*.duckdb
traces/
cache/

# Local PDFs that shouldn't be committed (corpus is sourced via script).
# Match both the legacy single-corpus layout (corpus/raw/*.pdf) and
# the namespaced multi-corpus layout (corpus/raw/<id>/*.pdf).
corpus/raw/*.pdf
corpus/raw/**/*.pdf
!corpus/raw/.gitkeep

# Derived text caches from PDFs (regenerable from corpus/raw/)
.corpus-cache/

# Editor / OS
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.swp
*~
